rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ─────────────────────────────────────────────────────────────
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Guard against oversized string fields to prevent resource-exhaustion writes.
    function validString(s, maxLen) {
      return s is string && s.size() <= maxLen;
    }

    function validNonEmptyString(s, maxLen) {
      return validString(s, maxLen) && s.size() > 0;
    }

    function validDateString(s) {
      return s is string
        && s.size() == 10
        && s.matches('^\\d{4}-\\d{2}-\\d{2}$');
    }

    function validTimeString(s) {
      return s is string && s.matches('^([01]\\d|2[0-3]):[0-5]\\d$');
    }

    function isNumber(value) {
      return value is int || value is float;
    }

    function validTaskSource(source) {
      return source in [
        'google_tasks',
        'google_calendar',
        'eventkit_reminders',
        'eventkit_calendar',
      ];
    }

    function validPointsReason(reason) {
      return reason in [
        'task_completed',
        'achievement_bonus',
        'daily_complete_bonus',
        'streak_bonus',
        'onboarding_bonus',
      ];
    }

    function validAchievementType(type) {
      return type in [
        'first_task',
        'first_brush',
        'right_place',
        'worth_wait',
        'custom_cat',
        'out_about',
        'early_bird',
        'day_complete',
        'on_a_roll',
        'explorer',
        'centurion',
        'challenge_winner',
      ];
    }

    function validTaskData(data) {
      return data.keys().hasOnly([
          'title',
          'category',
          'done',
          'description',
          'time',
          'source',
          'poi',
          'poiPlaceId',
          'completedPlaceId',
          'completedPlaceName',
          'completedPoiType',
          'poiAlertSeenDate',
          'exitPromptSeenDate',
          'createdAt',
          'completedAt',
          'date',
          'originDate',
          'pendingSync',
          'kind',
        ])
        && validNonEmptyString(data.title, 500)
        && validNonEmptyString(data.category, 120)
        && data.done is bool
        && (!('description' in data.keys()) || validString(data.description, 2000))
        && (!('time' in data.keys()) || validTimeString(data.time))
        && (!('source' in data.keys()) || validTaskSource(data.source))
        && (!('poi' in data.keys()) || validString(data.poi, 100))
        && (!('poiPlaceId' in data.keys()) || validString(data.poiPlaceId, 200))
        && (!('completedPlaceId' in data.keys()) || validString(data.completedPlaceId, 200))
        && (!('completedPlaceName' in data.keys()) || validString(data.completedPlaceName, 200))
        && (!('completedPoiType' in data.keys()) || validString(data.completedPoiType, 100))
        && (!('poiAlertSeenDate' in data.keys()) || validDateString(data.poiAlertSeenDate))
        && (!('exitPromptSeenDate' in data.keys()) || validDateString(data.exitPromptSeenDate))
        && data.createdAt is timestamp
        && (!('completedAt' in data.keys()) || data.completedAt is timestamp)
        && validDateString(data.date)
        && (!('originDate' in data.keys()) || validDateString(data.originDate))
        && (!('pendingSync' in data.keys()) || data.pendingSync is bool)
        && (!('kind' in data.keys()) || data.kind == 'birthday');
    }

    function validCategoryData(data) {
      return data.keys().hasOnly(['name', 'color', 'poi', 'isBuiltIn'])
        && validNonEmptyString(data.name, 80)
        && data.color is string
        && data.color.matches('^#[0-9A-Fa-f]{6}$')
        && (data.poi == null || validString(data.poi, 100))
        && data.isBuiltIn == false;
    }

    function validTripData(data) {
      return data.keys().hasOnly([
          'destination',
          'placeRef',
          'centerLat',
          'centerLng',
          'startDate',
          'endDate',
          'areaRadius',
          'cacheAreaId',
          'expiresAt',
          'preRefreshedAt',
          'kind',
          'createdAt',
        ])
        && validNonEmptyString(data.destination, 120)
        && validNonEmptyString(data.placeRef, 200)
        && isNumber(data.centerLat)
        && data.centerLat >= -90
        && data.centerLat <= 90
        && isNumber(data.centerLng)
        && data.centerLng >= -180
        && data.centerLng <= 180
        && (!('startDate' in data.keys()) || validDateString(data.startDate))
        && (!('endDate' in data.keys()) || validDateString(data.endDate))
        && data.areaRadius is int
        && data.areaRadius > 0
        && validNonEmptyString(data.cacheAreaId, 200)
        && data.expiresAt is int
        && data.expiresAt > 0
        && (!('preRefreshedAt' in data.keys()) || (data.preRefreshedAt is int && data.preRefreshedAt > 0))
        && (!('kind' in data.keys()) || data.kind == 'offgrid')
        && data.createdAt is timestamp;
    }

    function validMallSnapshotData(data) {
      return data.keys().hasOnly([
          'placeId',
          'name',
          'centerLat',
          'centerLng',
          'radius',
          'cacheAreaId',
          'expiresAt',
          'createdAt',
        ])
        && validNonEmptyString(data.placeId, 200)
        && validNonEmptyString(data.name, 120)
        && isNumber(data.centerLat)
        && data.centerLat >= -90
        && data.centerLat <= 90
        && isNumber(data.centerLng)
        && data.centerLng >= -180
        && data.centerLng <= 180
        && data.radius is int
        && data.radius > 0
        && validNonEmptyString(data.cacheAreaId, 200)
        && data.expiresAt is int
        && data.expiresAt > 0
        && data.createdAt is timestamp;
    }

    function validPoiPreferenceData(data, poiType) {
      return data.keys().hasOnly(['type', 'radiusMeters'])
        && data.type == poiType
        && validNonEmptyString(data.type, 100)
        && data.radiusMeters is int
        && data.radiusMeters > 0
        && data.radiusMeters <= 1000;
    }

    function validPointsHistoryData(data) {
      return data.keys().hasOnly(['taskId', 'taskTitle', 'awardedAt', 'points', 'reason'])
        && data.taskId is string
        && data.taskId.size() <= 200
        && validString(data.taskTitle, 500)
        && data.awardedAt is timestamp
        && data.points is int
        && data.points > 0
        && data.points <= 100
        && validPointsReason(data.reason);
    }

    function validAchievementDocData(data) {
      return data.keys().hasOnly(['type', 'earnedAt', 'metadata'])
        && validAchievementType(data.type)
        && data.earnedAt is timestamp
        && (!('metadata' in data.keys()) || (data.metadata is map && data.metadata.size() <= 5));
    }

    function validSharedTaskIncomingData(data) {
      return data.keys().hasOnly([
          'taskId',
          'title',
          'category',
          'poi',
          'sentBy',
          'sentByName',
          'sentByUsername',
          'sentAt',
          'status',
        ])
        && validNonEmptyString(data.taskId, 200)
        && validNonEmptyString(data.title, 500)
        && validNonEmptyString(data.category, 120)
        && (!('poi' in data.keys()) || validString(data.poi, 100))
        && validNonEmptyString(data.sentBy, 128)
        && validNonEmptyString(data.sentByName, 80)
        && (!('sentByUsername' in data.keys()) || validString(data.sentByUsername, 30))
        && data.sentAt is timestamp
        && data.status == 'pending';
    }

    function hasSharedTaskRelationship(senderUid, recipientUid) {
      return exists(/databases/$(database)/documents/users/$(senderUid)/following/$(recipientUid))
        || exists(/databases/$(database)/documents/users/$(senderUid)/followers/$(recipientUid));
    }

    function validTokenData(data) {
      return data.keys().hasOnly(['createdAt'])
        && data.createdAt is timestamp;
    }

    function validEodReminder(data) {
      return data is map
        && data.keys().hasOnly(['enabled', 'time'])
        && data.enabled is bool
        && validTimeString(data.time);
    }

    function validUserPreferencesData(data) {
      return data.keys().hasOnly([
          'exitPrompt',
          'eodReminder',
          'streakReminder',
          'achievementNudges',
          'weeklyRecap',
          'reengagementReminders',
          'friendActivity',
          'notif_nearby_enabled',
          'lastOpenedAt',
          'lastReengagementNudge',
          'reengagementChurned',
          'lastAchievementNudgeDate',
          'lastFriendNudgeFrom',
        ])
        && (!('exitPrompt' in data.keys()) || data.exitPrompt is bool)
        && (!('eodReminder' in data.keys()) || validEodReminder(data.eodReminder))
        && (!('streakReminder' in data.keys()) || data.streakReminder is bool)
        && (!('achievementNudges' in data.keys()) || data.achievementNudges is bool)
        && (!('weeklyRecap' in data.keys()) || data.weeklyRecap is bool)
        && (!('reengagementReminders' in data.keys()) || data.reengagementReminders is bool)
        && (!('friendActivity' in data.keys()) || data.friendActivity is bool)
        && (!('notif_nearby_enabled' in data.keys()) || data.notif_nearby_enabled is bool)
        && (!('lastOpenedAt' in data.keys()) || data.lastOpenedAt is timestamp)
        && (!('lastReengagementNudge' in data.keys()) || data.lastReengagementNudge is timestamp)
        && (!('reengagementChurned' in data.keys()) || data.reengagementChurned is timestamp)
        && (!('lastAchievementNudgeDate' in data.keys()) || validDateString(data.lastAchievementNudgeDate))
        && (!('lastFriendNudgeFrom' in data.keys()) || data.lastFriendNudgeFrom is map);
    }

    // ─── Username index (KAN-97) ──────────────────────────────────────────────
    // Public read so checkUsernameAvailable / getUserByUsername work for all
    // authenticated users. Write is restricted: you may only create/delete an
    // index entry that points to your own UID — enforcing single-owner claim.
    match /usernames/{username} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid
                    && validString(username, 20);
      // Deletion (username release on change): only the current owner may remove.
      allow delete: if request.auth != null
                    && resource.data.uid == request.auth.uid;
      // Updates are forbidden — changing a username = delete old + create new.
      allow update: if false;
    }

    // ─── User document ────────────────────────────────────────────────────────
    // Any authenticated user may read a profile (needed for public profile cards).
    // Only the document owner may write their own data.
    match /users/{userId} {
      allow read:  if request.auth != null;
      allow create: if isOwner(userId)
        && !request.resource.data.keys().hasAny([
          'totalPoints',
          'achievements',
          'currentStreak',
          'brushedPoiTypes',
        ]);
      allow delete: if false;
      allow update: if isOwner(userId)
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'totalPoints',
          'achievements',
          'currentStreak',
          'brushedPoiTypes',
        ]);
      // Cross-user counter update: only the followed user's followersCount may be
      // touched by a non-owner (the follower increments it on follow, decrements on
      // unfollow). followingCount is always on the caller's own doc, already covered
      // by isOwner above. Delta must be exactly +1 or -1 and result must be >= 0.
      allow update: if request.auth != null
        && !isOwner(userId)
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['followersCount'])
        && request.resource.data.followersCount is int
        && (request.resource.data.followersCount == resource.data.get('followersCount', 0) + 1
         || request.resource.data.followersCount == resource.data.get('followersCount', 0) - 1)
        && request.resource.data.followersCount >= 0;

      // ─── Tasks ──────────────────────────────────────────────────────────────
      match /tasks/{taskId} {
        allow read, delete: if isOwner(userId);
        allow create, update: if isOwner(userId)
          && validTaskData(request.resource.data);
      }

      // ─── Custom categories ───────────────────────────────────────────────────
      match /categories/{categoryId} {
        allow read, delete: if isOwner(userId);
        allow create, update: if isOwner(userId)
          && validCategoryData(request.resource.data);
      }

      // ─── Trips (KAN-234) ──────────────────────────────────────────────────────
      match /trips/{tripId} {
        allow read, delete: if isOwner(userId);
        allow create, update: if isOwner(userId)
          && validTripData(request.resource.data);
      }

      // ─── Mall snapshot (KAN-237) ─────────────────────────────────────────────
      match /mallSnapshot/current {
        allow read, delete: if isOwner(userId);
        allow create, update: if isOwner(userId)
          && validMallSnapshotData(request.resource.data);
      }

      // ─── POI preferences ─────────────────────────────────────────────────────
      match /pois/{poiType} {
        allow read, delete: if isOwner(userId);
        allow create, update: if isOwner(userId)
          && validPoiPreferenceData(request.resource.data, poiType);
      }

      // ─── Learned POI keywords (KAN-196) ──────────────────────────────────────
      match /learnedPoiKeywords/{docId} {
        allow read, delete: if isOwner(userId);
        allow create, update: if isOwner(userId)
          && request.resource.data.keys().hasOnly(['keyword', 'poi', 'lang', 'source', 'updatedAt'])
          && validString(request.resource.data.keyword, 200)
          && validString(request.resource.data.poi, 50)
          && request.resource.data.lang in ['en', 'pt-PT']
          && request.resource.data.source in ['llm', 'user']
          && request.resource.data.updatedAt is timestamp;
      }

      // ─── POI inference misses (KAN-254) ──────────────────────────────────────
      // Best-effort telemetry for phrases the local POI parser could not map.
      // Payload is intentionally tiny and contains no user identifiers beyond
      // the owning document path.
      match /poiInferenceMisses/{docId} {
        allow create: if isOwner(userId)
          && request.resource.data.keys().hasOnly(['sentence', 'createdAt'])
          && validString(request.resource.data.sentence, 200)
          && request.resource.data.sentence.size() > 0
          && request.resource.data.createdAt is timestamp;
        allow read, update, delete: if false;
      }

      // ─── Learned place visit counters (KAN-240) ──────────────────────────────
      match /learnedPlaceCounts/{placeId} {
        allow read, delete: if isOwner(userId);
        allow create, update: if isOwner(userId)
          && request.resource.data.keys().hasOnly(['placeId', 'name', 'poiType', 'visitCount'])
          && request.resource.data.placeId == placeId
          && validString(request.resource.data.name, 200)
          && validString(request.resource.data.poiType, 50)
          && request.resource.data.visitCount is int
          && request.resource.data.visitCount >= 0;
      }

      // ─── Achievements ────────────────────────────────────────────────────────
      // Any authenticated user may read achievements (KAN-105: friend comparison).
      // All writes are server-side only (KAN-271).
      match /achievements/{achievementId} {
        allow read:  if request.auth != null;
        allow create, update, delete: if false;
      }

      // ─── Points history ──────────────────────────────────────────────────────
      match /pointsHistory/{entryId} {
        allow read: if isOwner(userId);
        allow create, update, delete: if false;
      }

      // ─── FCM device tokens ───────────────────────────────────────────────────
      match /tokens/{token} {
        allow read, delete: if isOwner(userId);
        allow create, update: if isOwner(userId)
          && validTokenData(request.resource.data);
      }

      // ─── Notification preferences ────────────────────────────────────────────
      match /notificationPreferences/{doc} {
        allow read, write: if isOwner(userId);
      }

      // ─── User preferences (exitPrompt, lastOpenedAt, etc.) ───────────────────
      match /userPreferences/prefs {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId)
          && validUserPreferencesData(request.resource.data);
        allow delete: if false;
      }

      // ─── Reward claims (server-side idempotency markers) ─────────────────────
      match /rewardClaims/{claimId} {
        allow read, write: if false;
      }

      // ─── Social inbox (KAN-212) ──────────────────────────────────────────────
      // Owner reads, marks read (only the `read` field), or deletes their own entries.
      // Creators: validated shape + existsAfter guard (follower/following doc must
      // be present in the same batch) prevents spam/injection without a real follow.
      match /inbox/{entryId} {
        allow read, delete: if isOwner(userId);
        allow update: if isOwner(userId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
        allow create: if request.auth != null
          && request.resource.data.keys().hasOnly(['type', 'fromUid', 'fromUsername', 'fromDisplayName', 'read', 'createdAt'])
          && request.resource.data.type == 'follow_request'
          && request.resource.data.fromUid == request.auth.uid
          && validString(request.resource.data.fromUsername, 30)
          && validString(request.resource.data.fromDisplayName, 80)
          && request.resource.data.read is bool
          && request.resource.data.read == false
          && request.resource.data.createdAt is timestamp
          && existsAfter(/databases/$(database)/documents/users/$(userId)/followers/$(request.auth.uid));
      }

      // ─── Following (KAN-98) ──────────────────────────────────────────────────
      // The owner controls their own following list (who they choose to follow).
      // Any authenticated user may read (needed for friend pickers in KAN-101/102).
      match /following/{followedUid} {
        allow read:          if request.auth != null;
        allow create, delete: if isOwner(userId);
        allow update:        if false;
      }

      // ─── Followers (KAN-98) ──────────────────────────────────────────────────
      // Only the follower (document ID == their UID) may add/remove themselves.
      // Any authenticated user may read.
      match /followers/{followerUid} {
        allow read:          if request.auth != null;
        allow create, delete: if request.auth != null && request.auth.uid == followerUid;
        allow update:        if false;
      }
    }

    // ─── Shared tasks inbox (KAN-87) ──────────────────────────────────────────
    // The recipient (userId) owns the inbox. Senders need write access to
    // create incoming entries; recipients read and delete their own.
    match /sharedTasks/{userId}/incoming/{docId} {
      allow read, delete: if isOwner(userId);
      // Sender must match auth, payload must be well-formed, and an existing
      // follow relationship must already connect sender and recipient.
      allow create: if request.auth != null
                    && request.resource.data.sentBy == request.auth.uid
                    && validSharedTaskIncomingData(request.resource.data)
                    && hasSharedTaskRelationship(request.auth.uid, userId);
      allow update: if false;
    }

    // ─── Pending notifications (KAN-87 / KAN-221) ─────────────────────────────
    // Previously allowed any authenticated user to create an entry here as
    // long as they set sentBy == auth.uid — but nothing tied the write to a
    // real follow/share/challenge event, so any authenticated user could
    // spoof a notification (fake title/body) into another user's mailbox.
    // Creation now happens exclusively server-side via the onFollowRequest /
    // onSharedTaskCreated / onChallengeNotifications Cloud Functions (Admin
    // SDK, bypasses rules), each triggered off a write that is itself
    // already rule-validated. Clients may only read and delete their own
    // mailbox entries after local delivery.
    match /pendingNotifications/{userId}/items/{docId} {
      allow read, delete: if isOwner(userId);
      allow create, update: if false;
    }

    // ─── Challenges (KAN-102 / KAN-221) ───────────────────────────────────────
    // isValidParticipantsUpdate: onChallengeNotifications (KAN-221) treats a
    // participant's `won` flag flipping to true as a trusted signal that a
    // real win occurred, and fires challenge_won/challenge_ended notifications
    // off it. Without this guard, any participant or the creator could set
    // ANY other participant's `won`/`completedCount` and forge a challenge
    // outcome. Restricts a participants-map update to: only the caller's own
    // entry may change, completedCount may only increase, and won may only
    // flip false -> true.
    function isValidParticipantsUpdate() {
      let before = resource.data.participants;
      let after  = request.resource.data.participants;
      return after == before
        || (
          after.diff(before).affectedKeys().hasOnly([request.auth.uid])
          && after[request.auth.uid].diff(before[request.auth.uid]).affectedKeys()
               .hasOnly(['completedCount', 'won', 'status'])
          && after[request.auth.uid].completedCount >= before[request.auth.uid].completedCount
          && (after[request.auth.uid].won == before[request.auth.uid].won
              || after[request.auth.uid].won == true)
        );
    }

    match /challenges/{challengeId} {
      // Any participant or the creator may read the challenge.
      allow read: if request.auth != null && (
        resource.data.createdBy == request.auth.uid ||
        request.auth.uid in resource.data.participants
      );
      // Only the creator can create; createdBy must match their uid.
      allow create: if request.auth != null &&
        request.resource.data.createdBy == request.auth.uid;
      // Participants and the creator may update, but immutable fields (creator,
      // type, createdAt) cannot be changed after creation, and participants-map
      // mutations are restricted to the caller's own entry (see
      // isValidParticipantsUpdate).
      allow update: if request.auth != null
        && (resource.data.createdBy == request.auth.uid ||
            request.auth.uid in resource.data.participants)
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.type      == resource.data.type
        && request.resource.data.createdAt == resource.data.createdAt
        && isValidParticipantsUpdate();
      allow delete: if false;
    }

    // ─── Contact discovery index (KAN-99) ────────────────────────────────────
    // Hash → uid mapping. Only authenticated users may read or write their
    // own entry (uid in document must match the caller's auth uid).
    match /userDiscovery/{hash} {
      allow read:          if request.auth != null;
      allow create, update: if request.auth != null &&
        request.resource.data.uid == request.auth.uid;
      allow delete:        if request.auth != null &&
        resource.data.uid == request.auth.uid;
    }

    // ─── Health check ─────────────────────────────────────────────────────────
    match /_health/{document} {
      allow read:  if true;
      allow write: if false;
    }

    // ─── Catch-all: deny everything else ─────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
