# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

# Required for react-native-firebase (firebase-ios-sdk v9+)
$RNFirebaseAsStaticFramework = true
use_frameworks! :linkage => :static

# ── BrushShareExtension (KAN-91) ──────────────────────────────────────────────
# Native Swift Share Extension target. Needs Firebase directly (not through
# react-native-firebase) because it cannot load the React Native runtime.
#
# IMPORTANT: `inherit! :search_paths` means the extension uses the same pod
# build products as the Agenda target — no duplicate compilation. This requires
# the extension to be nested inside the Agenda target block in CocoaPods terms,
# OR listed here alongside. With `use_frameworks! :linkage => :static` the
# Firebase static libraries are linked separately into each binary, which is
# the correct behaviour for extensions.
#
# If you hit "duplicate symbols" during linking, see:
# https://firebase.google.com/docs/ios/troubleshooting#static-frameworks-extension
target 'BrushShareExtension' do
  pod 'FirebaseCore'
  pod 'FirebaseAuth'
  pod 'FirebaseFirestore'
  pod 'FirebaseFunctions'
end

target 'Agenda' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    installer.pods_project.targets.each do |target|
      if target.name.start_with?('RNFB')
        target.build_configurations.each do |config|
          config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
        end
        Pod::UI.puts "  ✔ #{target.name} included"
      end
    end

    # Fix: "declaration of 'RCTBridgeModule' / 'RCTConvert' must be imported from
    #       module 'RNFBApp.X' before it is required"
    #
    # With use_frameworks! :linkage => :static, RNFBApp is compiled first and its
    # Clang module "owns" React-Core types (RCTBridgeModule, RCTPromiseRejectBlock,
    # RCTConvert). Every subsequent RNFB pod must see those headers imported through
    # the RNFBApp module before any of its own headers are processed — otherwise the
    # compiler raises the error above.
    #
    # Two-pronged fix (both are required):
    #   1. Umbrella-header patch  — fixes EmitSwiftModule (Swift interface emission)
    #   2. GCC_PREFIX_HEADER      — fixes regular ObjC .m compilation
    #
    # Neither touches node_modules source files.

    rnfb_dependents = %w[RNFBAuth RNFBCrashlytics RNFBFirestore RNFBMessaging RNFBStorage]

    # ── 1. Umbrella-header patch ────────────────────────────────────────────────
    rnfb_dependents.each do |pod_name|
      umbrella = "#{installer.sandbox.root}/Target Support Files/#{pod_name}/#{pod_name}-umbrella.h"
      next unless File.exist?(umbrella)

      content = File.read(umbrella)
      next if content.include?('RNFBAppModule.h')

      first_import = content.match(/#import "RNFB[^"]+\.h"/)
      next unless first_import

      content.sub!(
        first_import[0],
        "#import <RNFBApp/RNFBAppModule.h>\n#import <RNFBApp/RCTConvert+FIRApp.h>\n#{first_import[0]}"
      )
      File.write(umbrella, content)
      Pod::UI.puts "  ✔ Patched #{pod_name}-umbrella.h"
    end

    # ── 2. GCC_PREFIX_HEADER for ObjC compilation units ────────────────────────
    # Write a tiny prefix header into the Pods sandbox (recreated each pod install).
    compat_header = "#{installer.sandbox.root}/RNFBCompat-prefix.h"
    File.write(compat_header, <<~COMPAT)
      // Auto-generated by Podfile post_install — do not edit.
      // Pre-imports RNFBApp headers so Clang module ownership is satisfied before
      // any other RNFB header is seen during ObjC compilation.
      #ifdef __OBJC__
      #import <RNFBApp/RNFBAppModule.h>
      #import <RNFBApp/RCTConvert+FIRApp.h>
      #endif
    COMPAT
    Pod::UI.puts '  ✔ Written RNFBCompat-prefix.h'

    installer.pods_project.targets.each do |target|
      next unless rnfb_dependents.include?(target.name)
      target.build_configurations.each do |cfg|
        cfg.build_settings['GCC_PREFIX_HEADER']           = '$(PODS_ROOT)/RNFBCompat-prefix.h'
        cfg.build_settings['GCC_PRECOMPILE_PREFIX_HEADER'] = 'YES'
      end
      Pod::UI.puts "  ✔ Prefix header applied to #{target.name}"
    end
  end
end
