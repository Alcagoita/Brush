require File.join(File.dirname(`node --print "require.resolve('expo/package.json')"`), "scripts/autolinking")
# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, '16.4'
prepare_react_native_project!

# Required for react-native-firebase (firebase-ios-sdk v9+)
$RNFirebaseAsStaticFramework = true
use_frameworks! :linkage => :static

# ── BrushShareExtension (KAN-91) ──────────────────────────────────────────────
# Native Swift Share Extension target. Needs Firebase directly (not through
# react-native-firebase) because it cannot load the React Native runtime.
#
# IMPORTANT: `inherit! :search_paths` means the extension uses the same pod
# build products as the Agenda target — no duplicate compilation. This requires
# the extension to be nested inside the Agenda target block in CocoaPods terms,
# OR listed here alongside. With `use_frameworks! :linkage => :static` the
# Firebase static libraries are linked separately into each binary, which is
# the correct behaviour for extensions.
#
# If you hit "duplicate symbols" during linking, see:
# https://firebase.google.com/docs/ios/troubleshooting#static-frameworks-extension
target 'BrushShareExtension' do
  pod 'FirebaseCore'
  pod 'FirebaseAuth'
  pod 'FirebaseFirestore'
  pod 'FirebaseFunctions'
end

target 'Brush' do
  use_expo_modules!

  if ENV['EXPO_USE_COMMUNITY_AUTOLINKING'] == '1'
    config_command = ['node', '-e', "process.argv=['', '', 'config'];require('@react-native-community/cli').run()"];
  else
    config_command = [
      'node',
      '--no-warnings',
      '--eval',
      'require(require.resolve(\'expo-modules-autolinking\', { paths: [require.resolve(\'expo/package.json\')] }))(process.argv.slice(1))',
      'react-native-config',
      '--json',
      '--platform',
      'ios'
    ]
  end

  config = use_native_modules!(config_command)

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # Two issues arise with RNFB + use_frameworks! :linkage => :static:
    #
    # 1. "Include of non-modular header inside framework module" — RNFB pods
    #    include React-Core headers (RCTBridgeModule.h, RCTConvert.h, etc.)
    #    which are non-modular. Fixed by CLANG_ALLOW_NON_MODULAR_INCLUDES.
    #
    # 2. RCT_EXTERN_MODULE/RCT_EXTERN_METHOD macros fail to expand ("type
    #    specifier missing") in RNFB ObjC .m files — Clang can't resolve
    #    RCTBridgeModule in each pod's framework module context even after (1).
    #    Fixed by pre-importing RNFBApp headers via GCC_PREFIX_HEADER before
    #    Clang enters framework module compilation for each dependent target.
    #    install_modules_dependencies() in RNFB v24 didn't eliminate this.
    #
    # Umbrella header patch — Swift EmitSwiftModule phase.
    # Each RNFB dependent pod's umbrella header must import RNFBApp headers
    # first so the Swift compiler sees RCTBridgeModule/RCTConvert ownership
    # established before any RNFB type appears in the generated Swift interface.
    # install_modules_dependencies() in RNFB v24 does not fix this path.
    rnfb_dependents = %w[RNFBAuth RNFBCrashlytics RNFBFirestore RNFBMessaging RNFBStorage]
    rnfb_dependents.each do |pod_name|
      umbrella = "#{installer.sandbox.root}/Target Support Files/#{pod_name}/#{pod_name}-umbrella.h"
      next unless File.exist?(umbrella)
      content = File.read(umbrella)
      next if content.include?('RNFBAppModule.h')
      first_import = content.match(/#import "RNFB[^"]+\.h"/)
      next unless first_import
      content.sub!(
        first_import[0],
        "#import <RNFBApp/RNFBAppModule.h>\n#import <RNFBApp/RCTConvert+FIRApp.h>\n#{first_import[0]}"
      )
      File.write(umbrella, content)
    end

    compat_header = "#{installer.sandbox.root}/RNFBCompat-prefix.h"
    File.write(compat_header, <<~COMPAT)
      // Auto-generated by Podfile post_install.
      // Pre-imports RNFBApp headers so RCTBridgeModule/RCTConvert ownership is
      // established before any RNFB dependent pod's ObjC compilation units run.
      #ifdef __OBJC__
      #import <RNFBApp/RNFBAppModule.h>
      #import <RNFBApp/RCTConvert+FIRApp.h>
      #endif
    COMPAT

    installer.pods_project.targets.each do |target|
      next unless target.name.start_with?('RNFB')
      target.build_configurations.each do |cfg|
        cfg.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
        cfg.build_settings['GCC_PREFIX_HEADER']            = '$(PODS_ROOT)/RNFBCompat-prefix.h'
        cfg.build_settings['GCC_PRECOMPILE_PREFIX_HEADER'] = 'YES'
      end
    end

    # BrushShareExtension: two build-setting fixes applied to the main project.
    #
    # 1. ENABLE_USER_SCRIPT_SANDBOXING — Xcode 15+ sandbox blocks CocoaPods'
    #    resource-copy script from writing resources-to-copy-BrushShareExtension.txt
    #    inside ios/Pods/. CocoaPods xcconfig does not override the target's
    #    explicit YES, so it must be set here.
    #
    # 2. GCC_PREFIX_HEADER — FirebaseAuth-Swift.h (pre-built framework header)
    #    references SafariServices and WebKit types. In the share extension
    #    compilation context these frameworks are not auto-imported, causing
    #    "No type or protocol named SFSafariViewControllerDelegate / WKNavigationDelegate"
    #    errors. A prefix header that imports SafariServices, WebKit, and FirebaseCore
    #    before any Firebase header is processed resolves this.
    share_ext_prefix = "#{installer.sandbox.root}/BrushShareExtCompat-prefix.h"
    File.write(share_ext_prefix, <<~HDR)
      // Auto-generated by Podfile post_install.
      #ifdef __OBJC__
      #import <SafariServices/SafariServices.h>
      #import <WebKit/WebKit.h>
      #import <FirebaseCore/FirebaseCore.h>
      #endif
    HDR

    main_proj = Xcodeproj::Project.open("#{installer.sandbox.root}/../Brush.xcodeproj")
    main_proj.targets.each do |target|
      next unless target.name == 'BrushShareExtension'
      target.build_configurations.each do |cfg|
        cfg.build_settings['ENABLE_USER_SCRIPT_SANDBOXING'] = 'NO'
        cfg.build_settings['GCC_PREFIX_HEADER']            = '$(PODS_ROOT)/BrushShareExtCompat-prefix.h'
        cfg.build_settings['GCC_PRECOMPILE_PREFIX_HEADER'] = 'YES'
      end
    end
    main_proj.save
  end
end
