# ─── Project-specific ────────────────────────────────────────────────────────

# Build outputs (APKs stored locally, not committed)
builds/

# Firebase config files — all variants committed (keys are restricted by bundle ID)
# Active files (google-services.json, GoogleService-Info.plist) default to DEV.
# Switch with: bash scripts/switch-env.sh [dev|staging|prod]

# Google Places API key — contains a real API key, must never be committed.
# Copy src/config/keys.example.ts → src/config/keys.ts and fill in your key.
src/config/keys.ts

# Emulator data (regenerated locally, not committed)
emulator-data/

