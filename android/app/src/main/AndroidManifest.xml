<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <!-- ── Notification permission (KAN-27) ── -->
    <!-- Required on Android 13+ (API 33+) for local notifications via notifee -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- ── Wear OS / Bluetooth permissions (KAN-35) ── -->
    <!--
      Required on Android 12+ (API 31+) for Wearable DataClient / MessageClient.
      NOTE: No runtime permission dialog is needed here. The Wearable Data Layer is
      mediated entirely by Google Play Services (GMS), which owns the Bluetooth session.
      The app never calls BluetoothAdapter directly — GMS handles pairing and transport.
      These declarations satisfy the manifest checker; GMS requests Bluetooth access on
      its own behalf when the user pairs a watch via the Wear OS companion app.
    -->
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADVERTISE" />

    <!-- ── Location permissions (KAN-22) ── -->
    <!-- Fine location — required for nearby POI search at 50–75 m accuracy -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <!-- Coarse location — fallback / battery-saver mode -->
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <!-- Background location — required so geofences fire when app is backgrounded -->
    <!-- Android 10+ requires this to be requested separately via the system dialog -->
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />
    <!-- Foreground service — needed to keep location alive when app is in background -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />

    <application
      android:name=".MainApplication"
      android:label="@string/app_name"
      android:icon="@mipmap/ic_launcher"
      android:roundIcon="@mipmap/ic_launcher_round"
      android:allowBackup="false"
      android:theme="@style/AppTheme"
      android:usesCleartextTraffic="${usesCleartextTraffic}"
      android:supportsRtl="true">
      <activity
        android:name=".MainActivity"
        android:label="@string/app_name"
        android:configChanges="keyboard|keyboardHidden|orientation|screenLayout|screenSize|smallestScreenSize|uiMode"
        android:launchMode="singleTask"
        android:windowSoftInputMode="adjustResize"
        android:exported="true">
        <intent-filter>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent-filter>

        <!-- ── Share intent receiver (KAN-90) ── -->
        <!-- Registers Brush as a text/plain share target. When the user shares  -->
        <!-- a message from WhatsApp, iMessage, etc., Android delivers it here. -->
        <!-- react-native-share-menu reads it via getInitialShare / listener.    -->
        <intent-filter>
            <action android:name="android.intent.action.SEND" />
            <category android:name="android.intent.category.DEFAULT" />
            <data android:mimeType="text/plain" />
        </intent-filter>
      </activity>

      <!-- ── Location foreground service (KAN-22) ── -->
      <!-- Keeps GPS alive when the app is backgrounded so geofences still fire. -->
      <service
        android:name="com.agontuk.RNFusedLocation.LocationUpdatesService"
        android:foregroundServiceType="location"
        android:exported="false" />

      <!-- ── Native geofence broadcast receiver (KAN-56) ── -->
      <!-- Receives GEOFENCE_TRANSITION_ENTER events from GeofencingClient. -->
      <receiver
        android:name=".GeofenceBroadcastReceiver"
        android:exported="false" />

      <!-- ── Wear OS message listener (KAN-38) ── -->
      <!-- Receives mark-done MessageClient messages from the watch companion. -->
      <service
        android:name=".WearMessageListenerService"
        android:exported="true">
        <intent-filter>
          <action android:name="com.google.android.gms.wearable.MESSAGE_RECEIVED" />
          <data
            android:host="*"
            android:pathPrefix="/brush/mark-done"
            android:scheme="wear" />
        </intent-filter>
      </service>
    </application>
</manifest>
