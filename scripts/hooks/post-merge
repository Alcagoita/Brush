#!/usr/bin/env bash
# post-merge hook — runs automatically after every git merge / git pull.
# Triggers an APK build only when merging into main (end of sprint).

CURRENT_BRANCH="$(git rev-parse --abbrev-ref HEAD)"

if [ "$CURRENT_BRANCH" != "main" ]; then
  exit 0
fi

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)/scripts"

echo ""
echo "🚀 Sprint release detected — building APK..."
bash "$SCRIPT_DIR/build-apk.sh"
